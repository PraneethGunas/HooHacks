# PolicyPulse — Environment Variables
# Copy to .env and fill in your values

# --- LLM API Keys (at least one required) ---
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# --- Data APIs (free, for Analyst Agent) ---
FRED_API_KEY=              # https://fred.stlouisfed.org/docs/api/api_key.html
BLS_API_KEY=               # https://www.bls.gov/developers/
TAVILY_API_KEY=            # https://tavily.com

# --- Lightning ---
# L402 payments handled by lnget (lightning-agent-tools).
# lnget config is auto-generated by the bootstrap script.
APERTURE_URL=http://localhost:8081
LNGET_MAX_COST_SATS=500

# --- App ---
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
